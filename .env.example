# ── Forge agent — environment ────────────────────────────────
# Copy to .env and fill in the secrets.

# HTTP
PORT=8787

# Agent identity
AGENT_NAME=forge
AGENT_VERSION=0.1.0
AGENT_DESCRIPTION=Generates ERC-8004 on-chain feedback payloads
AGENT_DOMAIN=forge-agent-production.up.railway.app
AGENT_ID=6482
REGISTER_IDENTITY=true

# Chain — Base Mainnet (eip155:8453)
CHAIN_ID=8453
NETWORK=base
RPC_URL=https://mainnet.base.org

# Payments / x402 (Coinbase CDP facilitator)
FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
PAYMENTS_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
PAYMENTS_NETWORK=base
PAYMENTS_PRICE=0.02
PAYMENTS_RECEIVABLE_ADDRESS=0x104b5768FE505c400dd98F447665CB5c6fca388A

# Secrets — DO NOT COMMIT
PRIVATE_KEY=
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
ANTHROPIC_API_KEY=

# IPFS pinning (Pinata) — leave empty until you have a JWT.
# Without it, /entrypoints/forge/invoke returns ready_to_sign:false.
PINATA_JWT=
